# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Environments ──────────────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── Google Earth Engine auth ──────────────────────────────────────────────────
.config/earthengine/
credentials
*.token
*.json
!aoi/*.json

# ── Data (large files — use DVC or share separately) ─────────────────────────
data/raw/*.tif
data/raw/*.zip
data/raw/*.tar.gz
data/raw/*.nc
data/raw/*.h5
data/raw/*.hdf5

# Keep processed CSVs and scene inventory in git
!data/raw/scene_inventory.csv
!data/processed/*.csv

# ── Outputs (figures regenerated by scripts) ──────────────────────────────────
outputs/figures/*.png
outputs/figures/*.pdf

# Keep tables and the paper
!outputs/tables/*.csv
!outputs/*.docx
!outputs/*.txt

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
